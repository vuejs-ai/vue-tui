{
  "name": "@vue-tui/testing",
  "version": "0.0.3",
  "description": "Deterministic test host for Vue terminal applications.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check:type": "tsc --noEmit",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@vue-tui/runtime": "workspace:*",
    "@xterm/addon-unicode11": "catalog:",
    "@xterm/headless": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
