+// Exit cleanly via the app lifecycle so the full-screen surface is restored on quit.
+// String rendering provides inert app and input services, so this same setup also works for --once.
+const { exit } = useApp();
+useInput((event) => {
+  const input =
+    event.kind === "text"
+      ? event.text
+      : event.kind === "key" &&
+          event.key.reportedText !== null &&
+          event.key.phase !== "release" &&
+          !event.key.modifiers.ctrl &&
+          !event.key.modifiers.alt &&
+          !event.key.modifiers.meta &&
+          !event.key.modifiers.super &&
+          !event.key.modifiers.hyper
+        ? event.key.reportedText
+        : "";
+  if (input === "q") {
+    exit();
+    return "consume";
+  }
+  if (input === "t") {
+    themeOverride.value = nextThemeMode(themeOverride.value);
+    return "consume";
+  }
+  return "continue";
+});
