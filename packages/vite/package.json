{
  "name": "@vue-tui/vite",
  "version": "0.2.0",
  "description": "Vite plugin for vue-tui: in-process terminal dev server with HMR.",
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "check:type": "tsc --noEmit",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vue-tui/runtime": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6",
    "@vue-tui/runtime": "0.1.1",
    "vite": "^8"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
