{
  "name": "@vue-tui/cli",
  "version": "0.0.2",
  "description": "Development server for Vue 3 terminal apps with Yoga flexbox layout.",
  "license": "MIT",
  "bin": {
    "vue-tui": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite-plus": "catalog:"
  }
}
